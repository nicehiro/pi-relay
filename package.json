{
  "name": "pi-relay",
  "version": "0.1.0",
  "description": "Discord bridge extension for pi — route messages, spawn sessions, stream output",
  "type": "module",
  "keywords": ["pi-package"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicehiro/pi-relay.git"
  },
  "files": [
    "dist",
    "config.example.yaml",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "https-proxy-agent": "^8.0.0",
    "yaml": "^2.7.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  }
}
